{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentic-cookbook-tools",
  "main": "src/worker.ts",
  "workers_dev": true,
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "routes": [
    { "pattern": "tools.agenticcookbook.com", "custom_domain": true },
    { "pattern": "tools.agentic-cookbook.com", "custom_domain": true }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tools-db",
      "database_id": "placeholder-create-with-wrangler-d1-create"
    }
  ]
}
