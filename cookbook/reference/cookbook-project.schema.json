{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-cookbook.com/schemas/cookbook-project.schema.json",
  "title": "Cookbook Project",
  "description": "Schema for cookbook-project.json — a platform-agnostic project definition format",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "name",
    "id",
    "version",
    "description",
    "author",
    "license",
    "created",
    "modified",
    "platforms",
    "cookbook"
  ],
  "properties": {
    "type": {
      "const": "cookbook-project",
      "description": "Identifies this file as a cookbook project"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Version of the project format itself (semver)"
    },
    "name": {
      "type": "string",
      "description": "Human-readable project name"
    },
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID — stable identity even if the directory is renamed"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Project version (semver)"
    },
    "description": {
      "type": "string",
      "description": "One-line description of the project"
    },
    "author": {
      "type": "string",
      "description": "Primary author"
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier"
    },
    "created": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date, immutable"
    },
    "modified": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date, updated on changes"
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Target platforms. Project-level default; components can override"
    },
    "cookbook": {
      "type": "object",
      "required": ["repo", "version"],
      "properties": {
        "repo": {
          "type": "string",
          "description": "Path or URL to the agentic-cookbook"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Cookbook version the project is based on"
        }
      },
      "additionalProperties": false
    },
    "resources": {
      "$ref": "#/$defs/resources"
    },
    "context": {
      "type": "object",
      "properties": {
        "research": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/context-entry"
          },
          "description": "Supporting evidence, evaluations, comparisons"
        },
        "decisions": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/context-entry"
          },
          "description": "Authoritative architectural decisions"
        },
        "notes": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/context-entry"
          },
          "description": "Informational notes, interview transcripts, freeform material"
        }
      },
      "additionalProperties": false
    },
    "components": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/component"
      },
      "description": "Top-level component tree"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "component": {
      "type": "object",
      "properties": {
        "recipe": {
          "type": "string",
          "description": "Relative path to the markdown recipe spec"
        },
        "description": {
          "type": "string",
          "description": "Short summary of the component"
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Platform override. Inherits from parent if absent"
        },
        "depends-on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Dot-path component keys this component depends on"
        },
        "source": {
          "type": "object",
          "required": ["domain", "version"],
          "properties": {
            "domain": {
              "type": "string",
              "description": "Cookbook domain identifier of the source recipe"
            },
            "version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$",
              "description": "Cookbook recipe version that was forked"
            }
          },
          "additionalProperties": false,
          "description": "Cookbook provenance — only present on forked recipes"
        },
        "resources": {
          "$ref": "#/$defs/resources"
        },
        "components": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/component"
          },
          "description": "Nested child components"
        }
      },
      "additionalProperties": false
    },
    "resource": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Resource category (localization, asset-catalog, app-manifest, sound, data)"
        },
        "path": {
          "type": "string",
          "description": "Relative path to the resource definition file"
        },
        "description": {
          "type": "string",
          "description": "What this resource contains"
        }
      },
      "additionalProperties": false
    },
    "resources": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/resource"
      },
      "description": "Named resource entries"
    },
    "context-entry": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["research", "decision", "note"],
          "description": "Signals to the LLM how to weigh the content"
        },
        "path": {
          "type": "string",
          "description": "Relative path to the markdown file"
        },
        "description": {
          "type": "string",
          "description": "Short summary"
        }
      },
      "additionalProperties": false
    }
  }
}
