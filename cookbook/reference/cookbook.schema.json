{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenticcookbook.dev/schemas/cookbook.schema.json",
  "title": "Cookbook",
  "description": "Schema for cookbook.json — a platform-agnostic project definition format that assembles recipes and ingredients into a complete application, plugin, or widget",
  "type": "object",
  "required": [
    "type", "schema_version", "name", "id", "version",
    "description", "author", "license", "created", "modified",
    "platforms", "cookbook"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON Schema reference for editor support"
    },
    "type": {
      "const": "cookbook",
      "description": "Identifies this file as a cookbook"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Version of the cookbook format itself (semver)"
    },
    "name": {
      "type": "string",
      "description": "Human-readable cookbook name"
    },
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID — stable identity even if the cookbook directory is renamed"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Cookbook version (semver)"
    },
    "description": {
      "type": "string",
      "description": "One-line description of the cookbook"
    },
    "author": {
      "type": "string",
      "description": "Primary author"
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier"
    },
    "created": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date, immutable"
    },
    "modified": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date, updated on changes"
    },
    "platforms": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Target platforms. Cookbook-level default; structural elements can override"
    },
    "cookbook": {
      "type": "object",
      "required": ["repo", "version"],
      "properties": {
        "repo": {
          "type": "string",
          "description": "Path or URL to the agentic-cookbook"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Top-level cookbook version this cookbook is based on"
        }
      },
      "additionalProperties": false
    },
    "resources": {
      "$ref": "#/$defs/resources"
    },
    "context": {
      "type": "object",
      "properties": {
        "research": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/context-entry" },
          "description": "Supporting evidence, evaluations, comparisons"
        },
        "decisions": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/context-entry" },
          "description": "Authoritative architectural decisions"
        },
        "notes": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/context-entry" },
          "description": "Informational notes, interview transcripts, freeform material"
        }
      },
      "additionalProperties": false
    },
    "structure": {
      "$ref": "#/$defs/structural-element",
      "description": "The single top-level structure being built (an app, plugin, widget, etc.)"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "structural-element": {
      "type": "object",
      "properties": {
        "spec": {
          "type": "string",
          "description": "Relative path to the markdown spec file (ingredient or recipe)"
        },
        "description": {
          "type": "string",
          "description": "Short summary of this structural element"
        },
        "platforms": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Platform override. Inherits from parent if absent"
        },
        "depends-on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Dot-path structural element keys this element depends on"
        },
        "source": {
          "type": "object",
          "required": ["domain", "version"],
          "properties": {
            "domain": {
              "type": "string",
              "description": "Cookbook domain identifier of the source ingredient or recipe"
            },
            "version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$",
              "description": "Cookbook artifact version that was forked"
            }
          },
          "additionalProperties": false,
          "description": "Cookbook provenance — only present on forked artifacts"
        },
        "resources": {
          "$ref": "#/$defs/resources"
        },
        "structural-elements": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/structural-element"
          },
          "description": "Child structural elements"
        }
      },
      "additionalProperties": false
    },
    "resource": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Resource category (localization, asset-catalog, app-manifest, sound, data)"
        },
        "path": {
          "type": "string",
          "description": "Relative path to the resource definition file"
        },
        "description": {
          "type": "string",
          "description": "What this resource contains"
        }
      },
      "additionalProperties": false
    },
    "resources": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/resource"
      },
      "description": "Named resource entries"
    },
    "context-entry": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["research", "decision", "note"],
          "description": "Signals to the LLM how to weigh the content"
        },
        "path": {
          "type": "string",
          "description": "Relative path to the markdown file"
        },
        "description": {
          "type": "string",
          "description": "Short summary"
        }
      },
      "additionalProperties": false
    }
  }
}
